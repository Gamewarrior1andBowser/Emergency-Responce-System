<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Emergency_Responce_System</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Emergency_Responce_System.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white shadow-sm px-4 mb-3">
            <div class="container-fluid">

                <!-- Brand -->
                <a class="navbar-brand fw-bold text-primary" asp-area="" asp-controller="Home" asp-action="Index">
                    Emergency System
                </a>

                <!-- Toggle -->
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <!-- Nav Items -->
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">

                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">

                        <li class="nav-item me-3">
                            <a class="nav-link text-dark fw-semibold" asp-controller="Home" asp-action="Index">Home</a>
                        </li>

                        <li class="nav-item me-3">
                            <a class="nav-link text-dark fw-semibold" asp-controller="Incidents" asp-action="Index">Incidents</a>
                        </li>

                        <li class="nav-item me-3">
                            <a class="nav-link text-dark fw-semibold" asp-controller="IncidentUpdates" asp-action="Index">Updates</a>
                        </li>

                        <li class="nav-item me-3">
                            <a class="nav-link text-dark fw-semibold" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>

                        @if (User.IsInRole("Admin") || User.IsInRole("Dispatcher"))
                        {
                            <li class="nav-item ms-4">
                                <a class="nav-link text-dark fw-semibold" asp-controller="Home" asp-action="Dashboard">Dashboard</a>
                            </li>
                        }

                    </ul>

                    <!-- Login / Logout -->
                    <partial name="_LoginPartial" />

                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - Emergency_Responce_System -
            <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>