@model Emergency_Responce_System.Models.IncidentUpdates

@{
    ViewData["Title"] = "Create Update";
}

<h2 class="mb-4">Add Incident Update</h2>

<div class="row">
    <div class="col-md-6">

        <form asp-action="Create">

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <!-- STATUS -->
            <div class="form-group mb-3">
                <label asp-for="Status" class="form-label"></label>
                <select asp-for="Status" class="form-control">
                    <option value="">-- Select Status --</option>
                    <option>Reported</option>
                    <option>In Progress</option>
                    <option>Resolved</option>
                    <option>Closed</option>
                </select>
                <span asp-validation-for="Status" class="text-danger"></span>
            </div>

            <!-- DESCRIPTION -->
            <div class="form-group mb-3">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control" rows="3"
                          placeholder="e.g. Ambulance dispatched, fire contained..."></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <!-- 🔥 CRITICAL FIX (DO NOT REMOVE) -->
            <input type="hidden" asp-for="IncidentID" value="@Model.IncidentID" />

            <!-- BUTTONS -->
            <div class="mt-4">
                <input type="submit" value="Add Update" class="btn btn-primary me-2" />
                <a asp-controller="Incidents" asp-action="Index" class="btn btn-outline-secondary">Back</a>
            </div>

        </form>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}