@model Emergency_Responce_System.Models.IncidentUpdates

@{
    ViewData["Title"] = "Create Update";
}

<h2 class="mb-4">Add Incident Update</h2>

<div class="row">
    <div class="col-md-6">

        <form asp-controller="IncidentUpdates" asp-action="Create" method="post">

            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="form-group mb-3">
                <label>Status</label>
                <select name="Status" class="form-control">
                    <option value="">-- Select Status --</option>
                    <option>Reported</option>
                    <option>In Progress</option>
                    <option>Resolved</option>
                    <option>Closed</option>
                </select>
            </div>

            <div class="form-group mb-3">
                <label>Description</label>
                <textarea name="Description" class="form-control"></textarea>
            </div>

            <!-- 🔥 FORCE VALUE -->
            <input type="hidden" name="IncidentID" value="@Model.IncidentID" />

            <div class="mt-4">
                <input type="submit" value="Add Update" class="btn btn-primary me-2" />
                <a asp-controller="Incidents" asp-action="Index" class="btn btn-outline-secondary">Back</a>
            </div>

        </form>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}